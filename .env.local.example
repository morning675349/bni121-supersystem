# Firebase 專案設定（來自 firebaseConfig，前端安全公開值）
FIREBASE_API_KEY=AIzaSy...
FIREBASE_PROJECT_ID=bni121-supersystem

# Firebase 服務帳戶金鑰（Console → 專案設定 → Service accounts → Generate new private key）
# 從下載的 JSON 檔複製對應欄位；private_key 貼上時保留 \n（不要真的換行）
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@bni121-supersystem.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# session cookie 簽章密鑰，自訂一組長隨機字串即可
SESSION_SECRET=change-me-to-a-long-random-string
